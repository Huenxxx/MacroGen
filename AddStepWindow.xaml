<Window x:Class="MacroCreatorApp.AddStepWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Añadir Paso" Height="480" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E" Foreground="#D4D4D4" FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="Fld" TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
        <Style x:Key="Rb" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="StdBtn" TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource StdBtn}">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="BorderBrush" Value="#1177BB"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1177BB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="AÑADIR PASO" FontSize="13" FontWeight="SemiBold"
                   Foreground="#0E639C" Margin="0,0,0,14"/>

        <!-- Type selector -->
        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Style="{StaticResource Lbl}" Text="TIPO DE ACCIÓN"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RbKey"   Style="{StaticResource Rb}" Content="⌨ Tecla"     IsChecked="True" Checked="TypeChanged"/>
                <RadioButton x:Name="RbDelay" Style="{StaticResource Rb}" Content="⏱ Espera"    Checked="TypeChanged"/>
                <RadioButton x:Name="RbText"  Style="{StaticResource Rb}" Content="✏ Texto"     Checked="TypeChanged"/>
                <RadioButton x:Name="RbMouse" Style="{StaticResource Rb}" Content="🖱 Ratón"     Checked="TypeChanged"/>
                <RadioButton x:Name="RbWheel" Style="{StaticResource Rb}" Content="⟳ Rueda"     Checked="TypeChanged"/>
            </StackPanel>
        </StackPanel>

        <!-- Panels -->
        <Grid Grid.Row="2">
            <!-- KEY -->
            <StackPanel x:Name="PanelKey" Visibility="Visible">
                <TextBlock Style="{StaticResource Lbl}" Text="TECLA (clic aquí y pulsa)"/>
                <Border x:Name="KeyCaptureBorder" Background="#252526" BorderBrush="#3C3C3C"
                        BorderThickness="1" CornerRadius="3" Padding="10" Cursor="Hand"
                        MouseDown="KeyCapture_Click" Margin="0,0,0,12">
                    <TextBlock x:Name="TbKeyCapture" Text="Haz clic aquí y pulsa una tecla..."
                               Foreground="#888888" FontFamily="Consolas" FontSize="12"/>
                </Border>
                <TextBlock Style="{StaticResource Lbl}" Text="ACCIÓN"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="RbActDownUp" Style="{StaticResource Rb}" Content="Pulsar (↓↑)" IsChecked="True"/>
                    <RadioButton x:Name="RbActDown"   Style="{StaticResource Rb}" Content="Bajar (↓)"/>
                    <RadioButton x:Name="RbActUp"     Style="{StaticResource Rb}" Content="Soltar (↑)"/>
                </StackPanel>
            </StackPanel>

            <!-- DELAY -->
            <StackPanel x:Name="PanelDelay" Visibility="Collapsed">
                <TextBlock Style="{StaticResource Lbl}" Text="DURACIÓN (ms)"/>
                <TextBox x:Name="TbDelayMs" Style="{StaticResource Fld}" Text="500"/>
            </StackPanel>

            <!-- TEXT -->
            <StackPanel x:Name="PanelText" Visibility="Collapsed">
                <TextBlock Style="{StaticResource Lbl}" Text="TEXTO A ESCRIBIR"/>
                <TextBox x:Name="TbText" Style="{StaticResource Fld}"/>
            </StackPanel>

            <!-- MOUSE -->
            <StackPanel x:Name="PanelMouse" Visibility="Collapsed">
                <TextBlock Style="{StaticResource Lbl}" Text="BOTÓN"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="RbML"     Style="{StaticResource Rb}" Content="Izquierdo" IsChecked="True"/>
                    <RadioButton x:Name="RbMR"     Style="{StaticResource Rb}" Content="Derecho"/>
                    <RadioButton x:Name="RbMM"     Style="{StaticResource Rb}" Content="Central"/>
                    <RadioButton x:Name="RbMX1"    Style="{StaticResource Rb}" Content="Lat 1"/>
                    <RadioButton x:Name="RbMX2"    Style="{StaticResource Rb}" Content="Lat 2"/>
                </StackPanel>
                <TextBlock Style="{StaticResource Lbl}" Text="ACCIÓN"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="RbMClick"  Style="{StaticResource Rb}" Content="Clic"       IsChecked="True"/>
                    <RadioButton x:Name="RbMDouble" Style="{StaticResource Rb}" Content="Doble Clic"/>
                    <RadioButton x:Name="RbMDown"   Style="{StaticResource Rb}" Content="Bajar"/>
                    <RadioButton x:Name="RbMUp"     Style="{StaticResource Rb}" Content="Soltar"/>
                </StackPanel>
                <CheckBox x:Name="CbAbsPos" IsChecked="False" Foreground="#D4D4D4" Cursor="Hand" Margin="0,0,0,8"
                          Content="Usar posición absoluta (coordenadas)" Checked="AbsPos_Changed" Unchecked="AbsPos_Changed"/>
                <StackPanel x:Name="PanelCoords" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="X:" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="TbMouseX" Style="{StaticResource Fld}" Width="60" Margin="0,0,12,0"/>
                    <TextBlock Text="Y:" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="TbMouseY" Style="{StaticResource Fld}" Width="60"/>
                    <Button Content="Usar actual" Style="{StaticResource StdBtn}" Margin="10,0,0,0"
                            Padding="8,4" Click="UseCurrentPos_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- WHEEL -->
            <StackPanel x:Name="PanelWheel" Visibility="Collapsed">
                <TextBlock Style="{StaticResource Lbl}" Text="DIRECCIÓN"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="RbWheelUp"   Style="{StaticResource Rb}" Content="↑ Arriba (adelante)" IsChecked="True"/>
                    <RadioButton x:Name="RbWheelDown" Style="{StaticResource Rb}" Content="↓ Abajo (atrás)"/>
                </StackPanel>
                <TextBlock Style="{StaticResource Lbl}" Text="CANTIDAD (múltiplos de 120)"/>
                <TextBox x:Name="TbWheelAmt" Style="{StaticResource Fld}" Text="120"/>
            </StackPanel>
        </Grid>

        <!-- Delay before -->
        <StackPanel Grid.Row="3" Margin="0,14,0,14">
            <TextBlock Style="{StaticResource Lbl}" Text="ESPERA ANTES DEL PASO (ms)"/>
            <TextBox x:Name="TbDelayBefore" Style="{StaticResource Fld}" Text="0"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Style="{StaticResource StdBtn}" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Añadir Paso" Style="{StaticResource AccentBtn}" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
